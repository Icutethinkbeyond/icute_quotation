generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================================================
// Accounting System - Prisma Schema Design
// รองรับ:
// - Multi Company
// - ผู้ใช้งานหลาย Role
// - ผังบัญชี (Chart of Accounts)
// - สมุดรายวัน (Journal Entry)
// - เดบิต / เครดิต
// - ลูกหนี้ / เจ้าหนี้
// - รายรับ / รายจ่าย
// - ใบแจ้งหนี้ / ใบเสร็จ
// - งบดุล / งบกำไรขาดทุน
// ======================================================

model User {
  userId   String  @id @default(uuid()) // Changed to uuid
  email    String  @unique
  password String?
  name     String?

  provider   ProviderAccount @default(Email)
  providerId String?         @unique

  userStatus      UserStatus @default(ACTIVE)
  isEmailVerified Boolean    @default(false)

  imageId  String?
  imageUrl String?

  role   Role?   @relation(fields: [roleId], references: [roleId])
  roleId String?

  companies CompanyUser[]

  verificationTokens VerificationToken[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  emailLogs     EmailLog[]
  lineLogs      LineLog[]
  notifications Notification[]

  ownedAccounts       Account[]
  ownedCompanies      Company[]
  ownedJournalEntries JournalEntry[]
  ownedCustomers      Customer[]
  ownedVendors        Vendor[]
  ownedContactors     Contactor[]
  ownedDocumentPapers DocumentPaper[]
  ownedCategories     Category[]
  ownedItems          Items[]
  ownedUnits          Unit[]
  ownedAboutItems     AboutItem[]
  ownedDocumentCategories DocumentCategory[]
  ownedDocumentItems DocumentItem[]
}

model CompanyUser {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

  @@unique([userId, companyId])
}

model VerificationToken {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [userId], onDelete: Cascade)
  token     String       @unique
  purpose   TokenPurpose
  expiresAt DateTime
  used      Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Role {
  roleId      String   @id @default(uuid())
  name        RoleName @unique
  description String?

  // Permissions - stored as JSON string array for flexibility
  permissions String @default("[]") // JSON array of permission names

  // Relations
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id         String      @id @default(cuid())
  companyId  String
  code       String
  name       String
  type       AccountType
  normalSide NormalSide
  isActive   Boolean     @default(true)
  parentId   String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  company  Company   @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  parent   Account?  @relation("AccountParent", fields: [parentId], references: [id])
  children Account[] @relation("AccountParent")

  journalLines JournalLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, code])
  @@index([userId])
}

// --------------------------------------
// Company & Business
// --------------------------------------

model Company {
  companyId               String    @id @default(uuid())
  companyName             String
  companyAddress          String?
  companyTaxId            String?
  branch                  String?
  companyPhoneNumber      String?
  companyEmail            String?
  companyWebsite          String?
  companyRegistrationDate DateTime?
  companyBusinessType     String?
  companyImage            String?
  companyImagePublicId    String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  customer       Customer[]
  companyUsers   CompanyUser[]
  accounts       Account[]
  journalEntries JournalEntry[]
  vendors        Vendor[]
  contactors     Contactor[]

  isDeleted  Boolean   @default(false)
  deletedAt DateTime?
  isFavorite Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ======================================================
// JOURNAL ENTRY
// ======================================================

model JournalEntry {
  id          String        @id @default(cuid())
  companyId   String
  journalNo   String
  date        DateTime
  description String?
  status      JournalStatus @default(DRAFT)

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  company Company       @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  lines   JournalLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, journalNo])
  @@index([userId])
}

model JournalLine {
  id          String  @id @default(cuid())
  journalId   String
  accountId   String
  description String?
  debit       Decimal @default(0) @db.Decimal(18, 2)
  credit      Decimal @default(0) @db.Decimal(18, 2)

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  createdAt DateTime @default(now())
}

model Customer {
  id        String      @id @default(cuid())
  companyId String
  customerType CustomerType @default(CORPORATION)
  name      String
  taxId     String?
  phone     String?
  email     String?
  address   String?
  website   String?
  note      String?
  branch          String?
  registrationDate DateTime?
  businessType    String?
  capital         Float?
  directorName    String?
  firstName       String?
  lastName        String?
  nationalId      String?
  dateOfBirth     DateTime?
  occupation      String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  company        Company         @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  documentPapers DocumentPaper[]

  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Vendor {
  id        String  @id @default(cuid())
  companyId String
  name      String
  taxId     String?
  phone     String?
  email     String?
  address   String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  company        Company         @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  documentPapers DocumentPaper[]

  createdAt DateTime @default(now())

  @@index([userId])
}

model Contactor {
  contactorId      String  @id @default(uuid())
  contactorName    String
  contactorEmail   String?
  contactorTel     String?
  contactorAddress String?

  company   Company? @relation(fields: [companyId], references: [companyId], onDelete: Cascade)
  companyId String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  documentPapers DocumentPaper[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  isStandalone Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// --------------------------------------
// Documents (Quotation/Invoice)
// --------------------------------------

model DocumentPaper {
  documentId   String @id @default(uuid())
  documentIdNo String @unique

  companyName    String?
  companyTel     String?
  companyAddress String?
  companyTaxId   String?
  companyBranch  String?

  docType         String
  docMonth        String?
  docYear         String?
  documentDetials String? // Keeping typo as requested

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  contactor   Contactor? @relation(fields: [contactorId], references: [contactorId])
  contactorId String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  documentType   eDocumentType  @default(Quotation)
  documentStatus DocumentStatus @default(Draft)

  documentCreateDate DateTime? @default(now())
  documentExpire     DateTime?

  includeVat     Boolean @default(false)
  taxRate        Float   @default(7)
  globalDiscount Float   @default(0)

  withholdingTax Float @default(0)

  note String?

  paymentDate DateTime
  method      PaymentMethod
  referenceNo String?

  categories DocumentCategory[]

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vendor    Vendor?  @relation(fields: [vendorId], references: [id])
  vendorId  String?

  @@index([userId])
}

model DocumentCategory {
  categoryId String @id @default(uuid())
  name       String

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  documentPaper   DocumentPaper @relation(fields: [documentPaperId], references: [documentId], onDelete: Cascade)
  documentPaperId String

  items DocumentItem[]

  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model DocumentItem {
  itemId String @id @default(uuid())

  name         String?
  description  String
  unit         String
  qty          Float   @default(1)
  pricePerUnit Float   @default(0)
  remark       String?

  totalPrice Float @default(0)

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  category   DocumentCategory @relation(fields: [categoryId], references: [categoryId], onDelete: Cascade)
  categoryId String

  orderIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// --------------------------------------
// Itemss Inventory
// --------------------------------------

model Category {
  categoryId   String  @id @default(uuid())
  categoryName String
  categoryDesc String?
  itemss       Items[]

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Items {
  itemsId          String  @id @default(uuid())
  itemsName        String
  itemsSKU         String?
  itemsDescription String?
  itemsImage       String?

  aboutItems AboutItem?
  category   Category?  @relation(fields: [categoryId], references: [categoryId])
  categoryId String?

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model AboutItem {
  aboutItemsId String @id @default(uuid())

  items   Items  @relation(fields: [itemsId], references: [itemsId], onDelete: Cascade)
  itemsId String @unique

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  itemsPrice         Float?  @default(0)
  itemsDiscountPrice Float?  @default(0)
  itemsStock         Int?    @default(0)
  itemsBrand         String?
  unitName           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// --------------------------------------
// Units Management
// --------------------------------------

model Unit {
  unitId     String @id @default(uuid())
  unitName   String @unique
  usageCount Int    @default(0)

  userId String?
  user   User?   @relation(fields: [userId], references: [userId], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ======================================================
// PAYMENT / RECEIPT
// ======================================================

// model Payment {
//   id          String        @id @default(cuid())
//   invoiceId   String?
//   amount      Decimal       @db.Decimal(18, 2)
//   paymentDate DateTime
//   method      PaymentMethod
//   referenceNo String?

//   companyId String
//   company   Company @relation(fields: [companyId], references: [companyId], onDelete: Cascade)

//   invoice Invoice? @relation(fields: [invoiceId], references: [id])

//   createdAt DateTime @default(now())
// }

model EmailLog {
  id      String  @id @default(uuid())
  to      String
  subject String
  type    String  @default("general") // verification, reset_password, notification, etc.
  success Boolean @default(true)
  error   String?

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model LineLog {
  id      String  @id @default(uuid())
  to      String
  type    String  @default("notification") // notification, booking, etc.
  success Boolean @default(true)
  error   String?

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// System-level settings for environment configuration (admin only)
model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique // e.g. LINE_CLIENT_ID, CLOUDINARY_CLOUD_NAME
  value String @db.Text // encrypted or plain text
  group String @default("general") // line, cloudinary, email

  // Help links for setup guides (stored as JSON string)
  helpLinks String @default("{}") // JSON: { "en": "url", "th": "url" }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(uuid())

  title         String
  message       String
  targetAddress String

  metadata String?

  type        NotificationType
  method      SendMethod
  targetGroup NotificationTarget

  isSent       Boolean   @default(false)
  isRead       Boolean   @default(false)
  sentAt       DateTime?
  errorMessage String?

  userId String
  user   User   @relation(fields: [userId], references: [userId], onDelete: Cascade)

  lineUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --------------------------------------
// Enums
// --------------------------------------

enum NotificationType {
  USER_NEW_REGISTRATION // Not About Booking, but for new store registration notification to admin
}

enum SendMethod {
  LINE_MESSAGING_API
  EMAIL
  WEBLOGIN
}

enum NotificationTarget {
  ADMIN
  SUPERADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum eDocumentType {
  Quotation // ใบเสนอราคา
  Bill // ใบเรียกเก็บเงิน
  Invoice //ใบเเจ้งหนี
  RECEIPT //PAYMENT / RECEIPT
}

enum DocumentStatus {
  Draft
  Waiting
  Approve
  Cancel
}

enum VerifiedStatus {
  Verified
  UnVerified
}

enum RoleName {
  SUPERADMIN
  ADMIN
  ACCOUNTANT
  STAFF
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalSide {
  DEBIT
  CREDIT
}

enum JournalStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  CHEQUE
}

enum ProviderAccount {
  Google
  Facebook
  Email
}

enum CustomerType {
  CORPORATION
  INDIVIDUAL
}
